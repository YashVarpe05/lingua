# Clerk Publishable Key (from your Clerk Dashboard)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Clerk Secret Key (server-side only, from your Clerk Dashboard)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Comma-separated origins allowed for Clerk token verification.
# Include every local API origin you use plus the deployed production origin.
CLERK_AUTHORIZED_PARTIES=http://localhost:8081,http://127.0.0.1:8081,http://[::1]:8081,https://your-deployment-url.example

# Public API/web origin used by native builds for Expo Router API routes.
EXPO_PUBLIC_API_BASE_URL=https://your-deployment-url.example

# PostHog Project Token (from your PostHog Project Settings)
POSTHOG_PROJECT_TOKEN=phc_your_posthog_project_token_here

# PostHog Host API URL
POSTHOG_HOST=https://us.i.posthog.com

# Supabase project URL and publishable key
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_your_publishable_key_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key_here

# Supabase server-only values
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-your-region.pooler.supabase.com:5432/postgres
# Optional: point backend QA at Supabase's database CA certificate for strict TLS.
# Download the project certificate from Supabase and keep it outside client code.
# DATABASE_SSL_CA_PATH=./certs/supabase-ca.pem
# Local-only fallback for machines that cannot validate the pooler certificate chain.
# Never use this with a deployed API_BASE_URL.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Gemini API Key (server-side only, from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
# Vision Agents' Gemini plugin also accepts GOOGLE_API_KEY. The local agent
# maps GEMINI_API_KEY to GOOGLE_API_KEY when GOOGLE_API_KEY is omitted.
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional Gemini model override
GEMINI_MODEL=gemini-2.5-flash

# Stream Video values (server-side only, from your Stream dashboard)
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Vision Agent service URL (server-side only)
# Local development can use http://127.0.0.1:8000.
# Production must use a deployed HTTPS service that EAS Hosting can reach.
VISION_AGENT_BASE_URL=http://127.0.0.1:8000

# Optional EAS Build setting for automatically deploying Expo Router server routes
EXPO_UNSTABLE_DEPLOY_SERVER=1
